# LinkedIn MCP server — copy to .env and fill in.
# Until partner approval, leave USE_MOCK_LINKEDIN=true to run with canned data.

USE_MOCK_LINKEDIN=true
# Keep current — /rest endpoints reject versions older than ~12 months.
LINKEDIN_API_VERSION=202605

# ── LinkedIn OAuth (member auth uses OpenID Connect: openid profile email) ──
LINKEDIN_CLIENT_ID=your_client_id
LINKEDIN_CLIENT_SECRET=your_client_secret
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_EXPIRY=

# Your company page org URN (urn:li:organization:<id>)
LINKEDIN_COMPANY_URN=urn:li:organization:0000000

# ── Database (shared with the TA backend — point at your Supabase pooler) ──
# If left blank, the server falls back to DATABASE_URL in the repo-root .env.
DATABASE_URL=
